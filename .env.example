# ==========================================================================
# Paklean BI - example environment file. Copy to .env and fill in real values.
# .env is gitignored to keep secrets out of version control.
# ==========================================================================

# === Primary (legacy) MongoDB 3.4 - read-only ===
DB_URI=mongodb://37.152.190.84:35456/pakleandb
DB_USERNAME=
DB_PASSWORD=
# Set to true to route primary traffic through a local SOCKS5 tunnel.
USE_PROXY=true
PROXY_HOST=127.0.0.1
PROXY_PORT=8080
PROXY_TYPE=socks5

# === Secondary (writable) MongoDB 8.0 - the local mirror ===
SECONDARY_USERNAME=paklean
SECONDARY_PASSWORD=change-me
SECONDARY_DB=pakleandb

# === Sync ===
SYNC_INTERVAL_SECONDS=60
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION=14

# === BI Panel (Next.js) ===
PANEL_PORT=3000
# The panel reads MONGO_HOST / MONGO_PORT / MONGO_USERNAME / MONGO_PASSWORD /
# MONGO_AUTH_SOURCE and builds the URI with URL-encoded userinfo, so passwords
# containing '@', ':' or '/' are safe. docker-compose passes these from the
# SECONDARY_* values above. Set MONGO_URI directly only for advanced cases.
BI_DB=bi
DATA_DB=${SECONDARY_DB}
# Default admin credentials seeded on first boot. Change after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# Random string (>=32 chars). Generate with: openssl rand -hex 48
JWT_SECRET=please-change-me-to-a-long-random-string-of-at-least-48-chars
JWT_TTL_HOURS=12
# OpenAI (used by /reports). Required for the reporting feature to work.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_USE_PROXY=false
# Hard caps applied to every LLM-generated pipeline.
REPORT_MAX_ROWS=1000
REPORT_MAX_TIME_MS=15000

# === Report cache (reuses past LLM answers to avoid extra cost) ============
# Provider for semantic similarity. Exact-match caching is always on.
#   none   = exact-match only (default; zero cost, zero deps)
#   hf     = HuggingFace Inference API (FREE tier) -- requires HF_API_KEY
#   openai = OpenAI text-embedding-3-small (paid but pennies/M tokens)
EMBEDDING_PROVIDER=none
HF_API_KEY=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_DAYS=30
